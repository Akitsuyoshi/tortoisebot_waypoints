<launch>

    <!--
    <node pkg="tortoisebot_waypoints"
          type="tortoisebot_action_server.py"
          name="tortoisebot_as"
          output="screen"/>
    -->
    <node pkg="tortoisebot_waypoints" type="reset_world_client.py" name="reset_world_client" />

    <test test-name="waypoint_action_test"
          pkg="tortoisebot_waypoints"
          type="test_waypoint_action.py">
        <param name="target_x" value="0.4" type="double" />
        <param name="target_y" value="0.4" type="double" />
    </test>

</launch>